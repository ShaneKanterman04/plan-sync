#!/usr/bin/env bash
set -euo pipefail

# plan — drive the plan-sync API and manage its local server.
#
# plan-sync runs locally, bound to 0.0.0.0 (reachable from your phone on the
# same network). This helper can start/stop that server and read/write the
# shared plan for the current workspace.
#
# Config (env, or skill config.env written by install.sh):
#   PLAN_API_URL    base URL of the app           (default http://localhost:3000)
#   PLAN_WORKSPACE  workspace name                (required for plan read/write)
#   PLAN_SYNC_DIR   path to the plan-sync app dir (required for `up`)
#   PLAN_HOST       host to bind                  (default 0.0.0.0)
#   PLAN_PORT       port to serve on              (default 3000)
#   PLAN_UPLOAD_ROOT local upload inbox           (default ./.plan-sync/uploads)
#   PLAN_API_TOKEN  optional bearer token (only if the server has auth enabled)

SELF="$(cd -- "$(dirname -- "$0")" && pwd)"
SKILL_ROOT="$(cd -- "${SELF}/.." && pwd)"
ENV_PLAN_API_URL_SET="${PLAN_API_URL+x}"; ENV_PLAN_API_URL="${PLAN_API_URL:-}"
ENV_PLAN_WORKSPACE_SET="${PLAN_WORKSPACE+x}"; ENV_PLAN_WORKSPACE="${PLAN_WORKSPACE:-}"
ENV_PLAN_SYNC_DIR_SET="${PLAN_SYNC_DIR+x}"; ENV_PLAN_SYNC_DIR="${PLAN_SYNC_DIR:-}"
ENV_PLAN_HOST_SET="${PLAN_HOST+x}"; ENV_PLAN_HOST="${PLAN_HOST:-}"
ENV_PLAN_PORT_SET="${PLAN_PORT+x}"; ENV_PLAN_PORT="${PLAN_PORT:-}"
ENV_PLAN_UPLOAD_ROOT_SET="${PLAN_UPLOAD_ROOT+x}"; ENV_PLAN_UPLOAD_ROOT="${PLAN_UPLOAD_ROOT:-}"
ENV_PLAN_API_TOKEN_SET="${PLAN_API_TOKEN+x}"; ENV_PLAN_API_TOKEN="${PLAN_API_TOKEN:-}"
# Defaults written at install time (uses ": ${VAR:=...}" so real env still wins).
[ -f "${SKILL_ROOT}/config.env" ] && . "${SKILL_ROOT}/config.env"
[ -f "${PWD}/.plan-sync/config.env" ] && . "${PWD}/.plan-sync/config.env"
[ -f "${PWD}/plan-sync.env" ] && . "${PWD}/plan-sync.env"
[ -n "$ENV_PLAN_API_URL_SET" ] && PLAN_API_URL="$ENV_PLAN_API_URL"
[ -n "$ENV_PLAN_WORKSPACE_SET" ] && PLAN_WORKSPACE="$ENV_PLAN_WORKSPACE"
[ -n "$ENV_PLAN_SYNC_DIR_SET" ] && PLAN_SYNC_DIR="$ENV_PLAN_SYNC_DIR"
[ -n "$ENV_PLAN_HOST_SET" ] && PLAN_HOST="$ENV_PLAN_HOST"
[ -n "$ENV_PLAN_PORT_SET" ] && PLAN_PORT="$ENV_PLAN_PORT"
[ -n "$ENV_PLAN_UPLOAD_ROOT_SET" ] && PLAN_UPLOAD_ROOT="$ENV_PLAN_UPLOAD_ROOT"
[ -n "$ENV_PLAN_API_TOKEN_SET" ] && PLAN_API_TOKEN="$ENV_PLAN_API_TOKEN"

API="${PLAN_API_URL:-http://localhost:3000}"
WS="${PLAN_WORKSPACE:-}"
TOKEN="${PLAN_API_TOKEN:-}"
HOST="${PLAN_HOST:-0.0.0.0}"
api_authority="${API#*://}"
api_authority="${api_authority%%/*}"
api_port=""
case "$api_authority" in
  *:*) api_port="${api_authority##*:}" ;;
esac
PORT="${PLAN_PORT:-${api_port:-3000}}"
BASE_URL="${API%/}"
PLAN_UPLOAD_ROOT="${PLAN_UPLOAD_ROOT:-${PWD}/.plan-sync/uploads}"

die() { echo "plan: $*" >&2; exit 1; }
need_py() { command -v python3 >/dev/null 2>&1 || die "python3 is required for this command"; }
need_ws() { [ -n "$WS" ] || die "set PLAN_WORKSPACE (e.g. export PLAN_WORKSPACE=hostlet)"; }

usage() {
  cat >&2 <<EOF
plan — drive the plan-sync API and its local server

Server:
  plan up                      start plan-sync locally on ${HOST}:${PORT} (background) if not already running
  plan serve [--host H] [--port P] [--workspace W]
                               start with explicit local-dev bind/workspace settings
  plan down                    stop the local server
  plan restart                 stop then start
  plan status-server           is the server healthy? print the URL
  plan doctor                  print config, server health, workspace status, and phone URL

Plan (needs PLAN_WORKSPACE="\${PLAN_WORKSPACE}"):
  plan get                     show plan + messages (JSON)
  plan show                    print the plan body markdown
  plan put [FILE] [--title T] [--type plan|summary|retrospective] [--sync-file F] [--linked-file F] [--ref F] [--doc SLUG]
                               write the primary plan body from FILE or stdin; with --doc, writes a named document
  plan docs                    list all documents in the workspace
  plan new <slug> [--title T] [--type plan|summary|retrospective] [--file F]
                               create/update a named document (body from --file, stdin if piped, or empty)
  plan status                  show current status/version
  plan status NEW [--note N]   set status: draft|review|changes_requested|approved|implementing|done
  plan msg [--kind K] [--doc SLUG] "TEXT"
                               post a message to the primary plan or named document (kind: note|check|progress|approve|request_changes|proof)
  plan messages [--since ISO]  list messages
  plan poll                    one-shot status+message snapshot
  plan preflight               check workspace files and stale approval metadata, then post a check message
  plan proof [--commit C] [--validation V] [--run-id R] [--note N]
                               append a structured final proof section and proof message
  plan export [--format markdown|json] [--out FILE]
                               export plan, messages, revisions, and metadata
  plan watch [--interval N] [--timeout S]
                               BLOCK, polling every N s (default 3), until the human approves,
                               requests changes, edits, or replies — then print what changed
  plan revisions               body revision history

Env/config: PLAN_API_URL, PLAN_WORKSPACE, PLAN_SYNC_DIR, PLAN_HOST, PLAN_PORT, PLAN_API_TOKEN
EOF
}

healthy() { curl -fsS "${BASE_URL}/api/health" >/dev/null 2>&1; }

lan_ip() { hostname -I 2>/dev/null | awk '{print $1}'; }

resolve_app_dir() {
  if [ -n "${PLAN_SYNC_DIR:-}" ] && [ -d "${PLAN_SYNC_DIR}" ]; then return; fi
  # Source-repo layout: <repo>/skill/plan-sync/scripts/plan -> repo is two up from skill root.
  local guess
  guess="$(cd -- "${SKILL_ROOT}/../.." 2>/dev/null && pwd || true)"
  if [ -n "$guess" ] && [ -f "$guess/package.json" ] && grep -q '"name": *"plan-sync"' "$guess/package.json" 2>/dev/null; then
    PLAN_SYNC_DIR="$guess"
    return
  fi
  die "set PLAN_SYNC_DIR to the plan-sync app directory (where its package.json lives)"
}

server_up() {
  if healthy; then
    echo "plan-sync already running at ${BASE_URL}"
    return 0
  fi
  resolve_app_dir
  command -v pnpm >/dev/null 2>&1 || die "pnpm is required to start the server"
  (
    cd "${PLAN_SYNC_DIR}"
    [ -d node_modules ] || { echo "installing deps…"; pnpm install; }
    [ -f .next/BUILD_ID ] || { echo "building (first run)…"; pnpm build; }
  )
  local log="${PLAN_SYNC_LOG:-/tmp/plan-sync.log}"
  local next_bin="${PLAN_SYNC_DIR}/node_modules/.bin/next"
  [ -x "$next_bin" ] || die "next binary not found at ${next_bin}; run pnpm install"
  echo "starting plan-sync on ${HOST}:${PORT} (logs: ${log})…"
  if command -v setsid >/dev/null 2>&1; then
    ( cd "${PLAN_SYNC_DIR}" && PLAN_UPLOAD_ROOT="${PLAN_UPLOAD_ROOT}" setsid -f "$next_bin" start -H "${HOST}" -p "${PORT}" </dev/null >"${log}" 2>&1 )
  else
    ( cd "${PLAN_SYNC_DIR}" && PLAN_UPLOAD_ROOT="${PLAN_UPLOAD_ROOT}" nohup "$next_bin" start -H "${HOST}" -p "${PORT}" </dev/null >"${log}" 2>&1 & )
  fi
  local i
  for i in $(seq 1 80); do healthy && break; sleep 0.5; done
  healthy || die "server did not become healthy — see ${log}"
  local ip; ip="$(lan_ip)"
  echo "up: ${BASE_URL}"
  [ -n "$ip" ] && echo "phone (same Wi-Fi): http://${ip}:${PORT}"
}

server_down() {
  local pid
  pid="$(ss -ltnp 2>/dev/null | grep ":${PORT}\b" | grep -oP 'pid=\K[0-9]+' | head -1 || true)"
  if [ -n "$pid" ]; then
    kill "$pid" 2>/dev/null && echo "stopped plan-sync (pid ${pid})"
  else
    echo "plan-sync not running on port ${PORT}"
  fi
}

pp() { if command -v jq >/dev/null 2>&1; then jq .; else cat; fi; }

# curl_json METHOD PATH [BODY] — no -f, so HTTP error bodies (the {error} JSON) are shown.
curl_json() {
  local m="$1" p="$2" b="${3:-}"
  if [ -n "$b" ]; then
    curl -sS -X "$m" "${BASE_URL}/api/w/${WS}${p}" -H 'Content-Type: application/json' ${TOKEN:+-H "Authorization: Bearer ${TOKEN}"} -d "$b"
  else
    curl -sS -X "$m" "${BASE_URL}/api/w/${WS}${p}" ${TOKEN:+-H "Authorization: Bearer ${TOKEN}"}
  fi
}

curl_root() {
  local m="$1" p="$2"
  curl -sS -X "$m" "${BASE_URL}${p}" ${TOKEN:+-H "Authorization: Bearer ${TOKEN}"}
}

# json_obj KEY=VALUE... — encode a JSON object (values are raw strings, may contain spaces/newlines).
json_obj() {
  need_py
  python3 -c '
import json, sys
o = {}
for a in sys.argv[1:]:
    k, _, v = a.partition("=")
    o[k] = v
print(json.dumps(o))' "$@"
}

json_plan_put() {
  need_py
  python3 - "$@" <<'PY'
import json
import sys

body_path = sys.argv[1]
args = sys.argv[2:]
with open(body_path, "r", encoding="utf-8") as handle:
    body = handle.read()
out = {"author": "agent", "bodyMd": body}
refs = []
sync_file = ""
for arg in args:
    key, _, value = arg.partition("=")
    if key == "ref":
        if value:
            refs.append(value)
    elif key in ("syncFile", "linkedFile"):
        if value:
            sync_file = value
    elif value:
        out[key] = value
files = []
if sync_file:
    out["linkedFile"] = sync_file
    files.append({"path": sync_file, "role": "sync"})
if refs:
    out["referencedFiles"] = refs
    files.extend({"path": ref, "role": "reference"} for ref in refs)
if files:
    out["files"] = files
print(json.dumps(out))
PY
}

json_proof() {
  need_py
  python3 - "$@" <<'PY'
import json
import sys

out = {"author": "agent", "commits": [], "validations": [], "runIds": [], "notes": []}
for arg in sys.argv[1:]:
    key, _, value = arg.partition("=")
    if not value:
        continue
    if key == "commit":
        out["commits"].append(value)
    elif key == "validation":
        out["validations"].append(value)
    elif key == "runId":
        out["runIds"].append(value)
    elif key == "note":
        out["notes"].append(value)
print(json.dumps(out))
PY
}

json_doc_post() {
  # json_doc_post SLUG BODY_FILE [key=value...]
  need_py
  python3 - "$@" <<'PY'
import json
import sys

slug = sys.argv[1]
body_path = sys.argv[2]
args = sys.argv[3:]
with open(body_path, "r", encoding="utf-8") as handle:
    body = handle.read()
out = {"author": "agent", "slug": slug, "bodyMd": body}
for arg in args:
    key, _, value = arg.partition("=")
    if value:
        out[key] = value
print(json.dumps(out))
PY
}

git_branch() { git rev-parse --abbrev-ref HEAD 2>/dev/null || true; }
git_sha() { git rev-parse --short=12 HEAD 2>/dev/null || true; }

cmd="${1:-help}"
shift || true

case "$cmd" in
  up) server_up ;;
  serve)
    serve_api=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --host) HOST="${2:-0.0.0.0}"; shift 2 ;;
        --port) PORT="${2:-3000}"; shift 2 ;;
        --workspace) WS="${2:-}"; shift 2 ;;
        --api-url) serve_api="${2:-}"; shift 2 ;;
        *) shift ;;
      esac
    done
    if [ -n "$serve_api" ]; then API="$serve_api"; else API="http://localhost:${PORT}"; fi
    BASE_URL="${API%/}"
    server_up
    [ -n "$WS" ] && echo "workspace: ${BASE_URL}/w/${WS}"
    ;;
  down) server_down ;;
  restart) server_down; sleep 1; server_up ;;
  status-server)
    if healthy; then
      ip="$(lan_ip)"; echo "healthy: ${BASE_URL}${ip:+  (phone: http://${ip}:${PORT})}"
    else
      echo "not running at ${BASE_URL}"; exit 1
    fi
    ;;
  doctor)
    ip="$(lan_ip)"
    echo "plan-sync doctor"
    echo "  api: ${BASE_URL}"
    echo "  host: ${HOST}"
    echo "  port: ${PORT}"
    echo "  workspace: ${WS:-<unset>}"
    echo "  app dir: ${PLAN_SYNC_DIR:-<unset>}"
    echo "  upload root: ${PLAN_UPLOAD_ROOT}"
    echo "  token configured: $([ -n "$TOKEN" ] && echo yes || echo no)"
    [ -n "$ip" ] && echo "  phone: http://${ip}:${PORT}${WS:+/w/${WS}}"
    if healthy; then
      echo "  health: ok"
      curl_root GET "/api/doctor" | pp
      if [ -n "$WS" ]; then
        echo "  workspace snapshot:"
        curl_json GET "/poll" | pp
      fi
    else
      echo "  health: not running"
      exit 1
    fi
    ;;
  get)
    need_ws; curl_json GET "" | pp
    ;;
  show)
    need_ws; need_py
    curl_json GET "" | python3 -c 'import sys, json; print(json.load(sys.stdin)["plan"]["bodyMd"])'
    ;;
  put)
    need_ws
    doc_slug=""; title=""; doc_type=""; sync_file=""; file="-"; refs=()
    while [ $# -gt 0 ]; do
      case "$1" in
        --doc) doc_slug="${2:-}"; shift 2 ;;
        --title) title="${2:-}"; shift 2 ;;
        --type) doc_type="${2:-}"; shift 2 ;;
        --sync-file|--linked-file) sync_file="${2:-}"; shift 2 ;;
        --ref) refs+=("ref=${2:-}"); shift 2 ;;
        *) file="$1"; shift ;;
      esac
    done
    tmp="$(mktemp)"
    if [ "$file" = "-" ]; then cat >"$tmp"; else cp "$file" "$tmp"; fi
    if [ -n "$doc_slug" ]; then
      args=()
      args+=("title=${title:-${doc_slug}}")
      [ -n "$doc_type" ] && args+=("documentType=${doc_type}")
      curl_json POST "/documents" "$(json_doc_post "$doc_slug" "$tmp" "${args[@]}")" | pp
    else
      args=()
      [ -n "$title" ] && args+=("title=${title}")
      [ -n "$doc_type" ] && args+=("documentType=${doc_type}")
      [ -n "$sync_file" ] && args+=("syncFile=${sync_file}")
      branch="$(git_branch)"; sha="$(git_sha)"
      [ -n "$branch" ] && args+=("sourceBranch=${branch}")
      [ -n "$sha" ] && args+=("sourceSha=${sha}")
      args+=("${refs[@]}")
      curl_json PUT "" "$(json_plan_put "$tmp" "${args[@]}")" | pp
    fi
    rm -f "$tmp"
    ;;
  status)
    need_ws
    if [ $# -gt 0 ] && [ "${1#-}" = "$1" ]; then
      new="$1"; shift; note=""
      while [ $# -gt 0 ]; do
        case "$1" in --note) note="${2:-}"; shift 2 ;; *) shift ;; esac
      done
      args=(author=agent "status=${new}")
      [ -n "$note" ] && args+=("note=${note}")
      curl_json PATCH "/status" "$(json_obj "${args[@]}")" | pp
    else
      curl_json GET "/status" | pp
    fi
    ;;
  msg)
    need_ws
    doc_slug=""; kind="note"
    while [ $# -gt 0 ]; do
      case "$1" in
        --doc) doc_slug="${2:-}"; shift 2 ;;
        --kind) kind="${2:-}"; shift 2 ;;
        *) break ;;
      esac
    done
    text="${1:-}"
    [ -n "$text" ] || die 'usage: plan msg [--kind K] [--doc SLUG] "message"'
    if [ -n "$doc_slug" ]; then
      curl_json POST "/d/${doc_slug}/messages" "$(json_obj author=agent "kind=${kind}" "body=${text}")" | pp
    else
      curl_json POST "/messages" "$(json_obj author=agent "kind=${kind}" "body=${text}")" | pp
    fi
    ;;
  messages)
    need_ws
    since=""
    while [ $# -gt 0 ]; do
      case "$1" in --since) since="${2:-}"; shift 2 ;; *) shift ;; esac
    done
    curl_json GET "/messages${since:+?since=${since}}" | pp
    ;;
  poll)
    need_ws; curl_json GET "/poll" | pp
    ;;
  preflight)
    need_ws; need_py
    bundle="$(curl_json GET "/export?format=json")"
    set +e
    python3 - "$bundle" <<'PY' > /tmp/plan-sync-preflight.txt
import json
import os
import subprocess
import sys

data = json.loads(sys.argv[1])
plan = data["plan"]
workspace_files = plan.get("files") or []
if not workspace_files:
    workspace_files = []
    if plan.get("linkedFile"):
        workspace_files.append({"path": plan["linkedFile"], "role": "sync"})
    workspace_files.extend({"path": path, "role": "reference"} for path in plan.get("referencedFiles", []))
normalized_files = []
unsafe = []
for item in workspace_files:
    raw = str(item.get("path", "")).strip()
    if not raw:
        continue
    if os.path.isabs(raw):
        unsafe.append(f"workspace file must be relative: {raw}")
        continue
    normalized = os.path.normpath(raw).replace("\\", "/")
    if normalized in (".", "..") or normalized.startswith("../"):
        unsafe.append(f"workspace file escapes the repo: {raw}")
        continue
    if normalized not in normalized_files:
        normalized_files.append(normalized)
missing = [path for path in normalized_files if not os.path.exists(path)]
branch = subprocess.run(["git", "rev-parse", "--abbrev-ref", "HEAD"], capture_output=True, text=True)
sha = subprocess.run(["git", "rev-parse", "--short=12", "HEAD"], capture_output=True, text=True)
current_branch = branch.stdout.strip() if branch.returncode == 0 else ""
current_sha = sha.stdout.strip() if sha.returncode == 0 else ""
problems = []
if missing:
    problems.append("missing workspace files: " + ", ".join(missing))
if unsafe:
    problems.extend(unsafe)
if plan.get("approvedSha") and current_sha and plan["approvedSha"] != current_sha:
    problems.append(f"git SHA changed since approval: {plan['approvedSha']} -> {current_sha}")
if plan.get("approvedBranch") and current_branch and plan["approvedBranch"] != current_branch:
    problems.append(f"git branch changed since approval: {plan['approvedBranch']} -> {current_branch}")
if data.get("staleReasons"):
    problems.extend(data["staleReasons"])
if problems:
    print("Preflight failed: " + "; ".join(dict.fromkeys(problems)))
    sys.exit(2)
print(
    f"Preflight OK: {len(normalized_files)} workspace files exist; "
    f"branch={current_branch or 'unknown'}; sha={current_sha or 'unknown'}."
)
PY
    rc=$?
    set -e
    text="$(cat /tmp/plan-sync-preflight.txt)"
    curl_json POST "/messages" "$(json_obj author=agent kind=check "body=${text}")" | pp
    rm -f /tmp/plan-sync-preflight.txt
    exit "$rc"
    ;;
  proof)
    need_ws
    args=()
    while [ $# -gt 0 ]; do
      case "$1" in
        --commit) args+=("commit=${2:-}"); shift 2 ;;
        --validation) args+=("validation=${2:-}"); shift 2 ;;
        --run-id) args+=("runId=${2:-}"); shift 2 ;;
        --note) args+=("note=${2:-}"); shift 2 ;;
        *) shift ;;
      esac
    done
    curl_json POST "/proof" "$(json_proof "${args[@]}")" | pp
    ;;
  export)
    need_ws
    format="markdown"; out=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --format) format="${2:-markdown}"; shift 2 ;;
        --out) out="${2:-}"; shift 2 ;;
        *) shift ;;
      esac
    done
    if [ -n "$out" ]; then
      curl_json GET "/export?format=${format}" >"$out"
      echo "exported ${WS} to ${out}"
    else
      curl_json GET "/export?format=${format}"
    fi
    ;;
  watch|wait)
    need_ws; need_py
    interval="${PLAN_WATCH_INTERVAL:-3}"; wtimeout=0
    while [ $# -gt 0 ]; do
      case "$1" in
        --interval) interval="${2:-3}"; shift 2 ;;
        --timeout) wtimeout="${2:-0}"; shift 2 ;;
        *) shift ;;
      esac
    done
    getf() { printf '%s' "$1" | python3 -c "import sys,json
try:
    d=json.load(sys.stdin); v=d.get('$2'); print('' if v is None else v)
except Exception:
    print('')" 2>/dev/null; }
    snap="$(curl_json GET "/poll")"
    s0="$(getf "$snap" status)"; v0="$(getf "$snap" version)"; c0="$(getf "$snap" messageCount)"; last0="$(getf "$snap" lastMessageAt)"
    echo "watching '${WS}' (status=${s0:-?}, v${v0:-?}, ${c0:-0} msgs) — polling every ${interval}s…" >&2
    started="$(date +%s 2>/dev/null || echo 0)"
    while true; do
      sleep "$interval"
      cur="$(curl_json GET "/poll" 2>/dev/null || echo '')"
      [ -n "$cur" ] || continue
      s="$(getf "$cur" status)"; [ -n "$s" ] || continue
      v="$(getf "$cur" version)"; c="$(getf "$cur" messageCount)"
      if [ "$s" != "$s0" ] || [ "$v" != "$v0" ] || [ "$c" != "$c0" ]; then
        echo "change: status ${s0}→${s} · v${v0}→${v} · msgs ${c0}→${c}" >&2
        printf '%s\n' "$cur" | pp
        if [ -n "$last0" ]; then new="$(curl_json GET "/messages?since=${last0}")"; else new="$(curl_json GET "/messages")"; fi
        echo "--- new messages ---" >&2
        if command -v jq >/dev/null 2>&1; then
          printf '%s' "$new" | jq -r '.messages[] | "[\(.author)/\(.kind)] \(.body)"'
        else
          printf '%s\n' "$new"
        fi
        exit 0
      fi
      if [ "$wtimeout" != "0" ]; then
        now="$(date +%s 2>/dev/null || echo 0)"
        [ $((now - started)) -ge "$wtimeout" ] && { echo "watch: timed out after ${wtimeout}s with no change" >&2; exit 2; }
      fi
    done
    ;;
  revisions)
    need_ws; curl_json GET "/revisions" | pp
    ;;
  docs)
    need_ws
    if command -v jq >/dev/null 2>&1; then
      curl_json GET "/documents" | jq -r '(.documents // [])[] | "\(.slug) · \(.documentType) · \(.title) · v\(.version) · \(.updatedAt) · (\(.messageCount) msgs)"'
    else
      curl_json GET "/documents" | python3 -c '
import sys, json
data = json.load(sys.stdin)
for d in (data.get("documents") or []):
    print("{slug} \xb7 {documentType} \xb7 {title} \xb7 v{version} \xb7 {updatedAt} \xb7 ({messageCount} msgs)".format(**d))
'
    fi
    ;;
  new)
    need_ws
    doc_slug="${1:-}"; shift || true
    [ -n "$doc_slug" ] || die 'usage: plan new <slug> [--title T] [--type T] [--file F]'
    title=""; doc_type=""; file=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --title) title="${2:-}"; shift 2 ;;
        --type) doc_type="${2:-}"; shift 2 ;;
        --file) file="${2:-}"; shift 2 ;;
        *) shift ;;
      esac
    done
    tmp="$(mktemp)"
    if [ -n "$file" ]; then
      cp "$file" "$tmp"
    elif [ ! -t 0 ]; then
      cat >"$tmp"
    else
      : >"$tmp"
    fi
    args=()
    args+=("title=${title:-${doc_slug}}")
    [ -n "$doc_type" ] && args+=("documentType=${doc_type}")
    curl_json POST "/documents" "$(json_doc_post "$doc_slug" "$tmp" "${args[@]}")" | pp
    rm -f "$tmp"
    ;;
  help|--help|-h)
    usage; exit 0
    ;;
  *)
    usage; die "unknown command: ${cmd}"
    ;;
esac
