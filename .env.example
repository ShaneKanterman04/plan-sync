# --- plan-sync server config ---

# Where the SQLite database lives. In the container this is the mounted volume.
DATA_DIR=/data

# Optional: set a token to require `Authorization: Bearer <token>` on all writes.
# Leave empty for the open MVP. Enabling it needs no code changes.
PLAN_API_TOKEN=

# --- Used by agents/the skill, not the server itself ---

# Base URL agents point the skill at (your hostlet public URL for this app).
PLAN_API_URL=http://localhost:3000
# Default workspace name agents use.
PLAN_WORKSPACE=hostlet
