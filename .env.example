# --- plan-sync (runs locally, bound to 0.0.0.0) ---

# Where the SQLite database lives. Default ./.data; persists across restarts.
# DATA_DIR=./.data

# Where phone uploads are written. install.sh defaults this to
# <target-workspace>/.plan-sync/uploads.
# PLAN_UPLOAD_ROOT=./.plan-sync/uploads

# Port to serve on (bound to 0.0.0.0). Default 3000.
# PLAN_PORT=3000

# Optional: require `Authorization: Bearer <token>` on all writes. Empty = open.
PLAN_API_TOKEN=

# --- Used by agents / the skill ---

# Base URL agents point the skill at.
PLAN_API_URL=http://localhost:3000
# Path to this app dir, so `plan up` can start the server. install.sh sets this.
# PLAN_SYNC_DIR=/abs/path/to/plan-sync
# Default workspace name agents use.
PLAN_WORKSPACE=hostlet

# --- Mandatory plugin/control layer ---

PLAN_AGENT_NAME=codex
PLAN_AGENT_CMD="codex exec"
PLAN_PREFLIGHT_CMD="pnpm typecheck && pnpm lint"
PLAN_VALIDATE_CMD="pnpm typecheck && pnpm lint && pnpm test"
PLAN_PLUGIN_POLL_INTERVAL=3
PLAN_PLUGIN_TIMEOUT=600
PLAN_APPROVAL_STRICT=1
