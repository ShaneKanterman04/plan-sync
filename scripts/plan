#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd)"

if [ "${1:-}" = "plugin" ]; then
  export PLAN_REPO_CWD="${PLAN_REPO_CWD:-$PWD}"
  cd "$REPO_ROOT"
  if [ ! -x "node_modules/.bin/tsx" ]; then
    corepack enable >/dev/null 2>&1 || true
    pnpm install --frozen-lockfile
  fi
  pnpm exec tsx scripts/plan-plugin.ts "$@"
  exit $?
fi

exec "$REPO_ROOT/skill/plan-sync/scripts/plan" "$@"
